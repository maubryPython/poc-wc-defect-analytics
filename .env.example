# ─────────────────────────────────────────────────────────────────────────────
# Nike WC Defect Analytics — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git (it is already in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── HuggingFace Inference API (POC-1) ────────────────────────────────────────
# Free token from https://huggingface.co/settings/tokens
# Used by: tools/llm_tools.py (llm_reason, llm_draft, fact_check)
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Model selection (optional override) ──────────────────────────────────────
# Default: mistralai/Mistral-7B-Instruct-v0.2
# Any free HuggingFace serverless inference model works here.
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# ── Databricks (local dev only — not needed inside Databricks notebooks) ─────
# Set these only if running agents locally against a remote Databricks cluster.
# Inside Databricks, use: dbutils.secrets.get(scope="nike-wc-poc", key="...")
DATABRICKS_HOST=https://<your-workspace>.azuredatabricks.net
DATABRICKS_TOKEN=dapi_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DATABRICKS_CLUSTER_ID=<your-cluster-id>

# ── Data paths ────────────────────────────────────────────────────────────────
# Override if your landing zone is not the default path.
LANDING_ZONE_PATH=dbfs:/mnt/landing/

# ── Agent thresholds (optional — defaults live in config/agent_config.yaml) ──
# Uncomment to override config file values at runtime.
# DETECTION_FLAG_THRESHOLD=2.0
# RCA_CONFIDENCE_THRESHOLD=0.70
# SUMMARY_SEVERITY_UNIT_THRESHOLD=5000
